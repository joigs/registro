<% content_for :title, "#{@fecha.nombre_mostrado} · #{@fecha.patente.nombre}" %>

<div data-controller="fotos-melon--admin--galeria fotos-melon--admin--modal fotos-melon--admin--uploader" class="space-y-5">
  <div class="flex items-center gap-3">
    <a href="<%= fotos_melon_admin_patente_path(@fecha.patente) %>" class="w-9 h-9 rounded-full bg-fm-bg-subtle border border-fm-border flex items-center justify-center hover:bg-fm-border-strong no-underline">
      <svg viewBox="0 0 24 24" class="w-5 h-5 text-fm-text" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <div class="flex-1">
      <h1 class="text-2xl font-bold tracking-tight"><%= @fecha.nombre_mostrado %></h1>
      <p class="text-sm text-fm-text-muted"><%= @fecha.patente.nombre %></p>
    </div>
    <button type="button" data-action="fotos-melon--admin--modal#open" data-modal-id="renombrar-fecha"
            class="px-4 py-2 rounded-full border border-fm-border hover:bg-fm-bg-subtle text-sm">Renombrar</button>
  </div>

  <div class="flex flex-wrap gap-2" data-fotos-melon--admin--galeria-target="barraNormal">
    <button type="button" data-action="fotos-melon--admin--uploader#abrir"
            class="bg-fm-accent hover:bg-fm-accent-deep text-white font-semibold px-5 py-2.5 rounded-full transition">Subir fotos</button>
    <% if @fotos.any? %>
      <a href="<%= descargar_fotos_melon_admin_fecha_path(@fecha) %>"
         class="px-5 py-2.5 rounded-full border border-fm-border hover:bg-fm-bg-subtle no-underline text-fm-text">Descargar carpeta</a>
    <% end %>
  </div>

  <div class="hidden flex-wrap items-center gap-2 bg-fm-accent-soft border border-fm-accent rounded-xl px-4 py-3"
       data-fotos-melon--admin--galeria-target="barraSeleccion">
    <span class="font-semibold text-fm-accent-deep"><span data-fotos-melon--admin--galeria-target="contador">0</span> seleccionadas</span>
    <div class="flex-1"></div>
    <button type="button" data-action="fotos-melon--admin--galeria#descargarSeleccionadas"
            class="px-4 py-2 rounded-full bg-fm-accent text-white font-semibold text-sm">Descargar</button>
    <button type="button" data-action="fotos-melon--admin--galeria#abrirMover"
            class="px-4 py-2 rounded-full border border-fm-accent text-fm-accent-deep bg-white font-semibold text-sm">Mover</button>
    <button type="button" data-action="fotos-melon--admin--galeria#abrirEliminar"
            class="px-4 py-2 rounded-full bg-fm-danger text-white font-semibold text-sm">Eliminar</button>
    <button type="button" data-action="fotos-melon--admin--galeria#limpiar"
            class="px-3 py-2 rounded-full bg-white border border-fm-border text-sm">Cancelar</button>
  </div>

  <%= form_with url: fotos_melon_admin_fecha_fotos_path(@fecha), method: :post, multipart: true,
                data: { "fotos-melon--admin--uploader-target": "form" }, class: "hidden" do %>
    <input type="file" name="imagenes[]" accept="image/*" multiple
           data-fotos-melon--admin--uploader-target="input"
           data-action="change->fotos-melon--admin--uploader#enviar" />
  <% end %>

  <% if @fotos.empty? %>
    <div class="bg-white border border-fm-border rounded-2xl p-12 text-center">
      <p class="text-fm-text-muted">Aún no hay fotos. Sube las primeras desde tu computador.</p>
    </div>
  <% else %>
    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      <% @fotos.each do |foto| %>
        <li class="relative group aspect-square rounded-xl overflow-hidden border border-fm-border bg-fm-bg-subtle cursor-pointer"
            data-fotos-melon--admin--galeria-target="item" data-foto-id="<%= foto.id %>"
            data-action="click->fotos-melon--admin--galeria#clickItem">
          <img src="<%= ver_fotos_melon_admin_foto_path(foto) %>" loading="lazy"
               class="w-full h-full object-cover" alt="<%= foto.nombre %>" />
          <div class="absolute inset-x-0 bottom-0 bg-black/45 px-2 py-1">
            <span class="text-white text-[11px] truncate block"><%= foto.subido_por_nombre %></span>
          </div>
          <div class="absolute top-2 right-2 w-6 h-6 rounded-full border-2 border-white bg-white/80 hidden items-center justify-center"
               data-fotos-melon--admin--galeria-target="check">
            <svg viewBox="0 0 24 24" class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>

  <script type="application/json" data-fotos-melon--admin--galeria-target="datos">
    <%= raw({
              fechaActualId: @fecha.id,
              verUrlBase: "/ventas/fotos_melon/admin/fotos/",
              zipUrl: descargar_zip_fotos_melon_admin_fotos_path,
              csrf: form_authenticity_token,
              patentes: FotosMelon::Patente.order(:nombre).map { |p| { id: p.id, nombre: p.nombre, esActual: p.id == @fecha.patente_id } }
            }.to_json) %>
  </script>

  <div data-fotos-melon--admin--galeria-target="lightbox"
       class="fixed inset-0 z-50 bg-black/92 hidden items-center justify-center"
       data-action="click->fotos-melon--admin--galeria#cerrarLightbox">
    <button type="button" data-action="fotos-melon--admin--galeria#cerrarLightbox"
            class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/15 text-white flex items-center justify-center text-2xl">&times;</button>
    <img data-fotos-melon--admin--galeria-target="lightboxImg" class="max-w-[92vw] max-h-[80vh] object-contain" />
    <div class="absolute bottom-4 inset-x-0 flex justify-center gap-2 px-4" data-action="click->stop">
      <a data-fotos-melon--admin--galeria-target="lightboxDescargar"
         class="px-4 py-2 rounded-full bg-fm-accent text-white font-semibold text-sm no-underline">Descargar</a>
      <button type="button" data-action="fotos-melon--admin--galeria#renombrarActual"
              class="px-4 py-2 rounded-full bg-white text-fm-text font-semibold text-sm">Renombrar</button>
      <button type="button" data-action="fotos-melon--admin--galeria#eliminarActual"
              class="px-4 py-2 rounded-full bg-fm-danger text-white font-semibold text-sm">Eliminar</button>
    </div>
  </div>

  <%= render "fotos_melon/admin/shared/modal", id: "mover-fotos", titulo: "Mover fotos" do %>
    <p class="text-sm text-fm-text-muted mb-3">Elige la carpeta destino.</p>
    <div class="space-y-2 max-h-80 overflow-y-auto" data-fotos-melon--admin--galeria-target="moverLista">
      <p class="text-fm-text-muted text-sm">Cargando...</p>
    </div>
  <% end %>

  <%= form_with url: "#", method: :delete, data: { "fotos-melon--admin--galeria-target": "formEliminar" }, class: "hidden" do %><% end %>


  <%= form_with url: "#", method: :post, data: { "fotos-melon--admin--galeria-target": "formMover" }, class: "hidden" do %>
    <input type="hidden" name="fecha_carpeta_id" data-fotos-melon--admin--galeria-target="formMoverDestino" />
  <% end %>

  <%= render "fotos_melon/admin/shared/modal", id: "renombrar-fecha", titulo: "Renombrar carpeta" do %>
    <%= form_with url: fotos_melon_admin_fecha_path(@fecha), method: :patch, local: true, class: "space-y-4" do %>
      <div>
        <label class="block text-xs uppercase text-fm-text-muted font-medium mb-1">Nuevo nombre</label>
        <input type="text" name="nombre_personalizado" value="<%= @fecha.nombre_personalizado %>" placeholder="Ej: Inspección final"
               class="w-full px-4 py-3 rounded-lg border border-fm-border focus:outline-none focus:ring-2 focus:ring-fm-accent-ring focus:border-fm-accent" />
      </div>
      <div>
        <label class="block text-xs uppercase text-fm-text-muted font-medium mb-1">Para confirmar, escribe "<%= @fecha.nombre_mostrado %>"</label>
        <input type="text" name="confirmacion_nombre" autocomplete="off" class="w-full px-4 py-3 rounded-lg border border-fm-border focus:outline-none focus:ring-2 focus:ring-fm-accent-ring focus:border-fm-accent" />
      </div>
      <div class="flex justify-end gap-2">
        <button type="button" data-action="fotos-melon--admin--modal#close" class="px-4 py-2.5 rounded-full border border-fm-border hover:bg-fm-bg-subtle">Cancelar</button>
        <button type="submit" class="px-5 py-2.5 rounded-full bg-fm-accent hover:bg-fm-accent-deep text-white font-semibold">Guardar</button>
      </div>
    <% end %>
  <% end %>

  <div data-fotos-melon--admin--uploader-target="overlay" class="fixed inset-0 z-50 bg-black/40 hidden items-center justify-center">
    <div class="bg-white rounded-2xl p-8 text-center max-w-sm mx-4">
      <div class="w-12 h-12 mx-auto mb-4 border-4 border-fm-accent border-t-transparent rounded-full animate-spin"></div>
      <p class="font-semibold">Subiendo fotos...</p>
      <p class="text-sm text-fm-text-muted mt-1">No cierres esta ventana.</p>
    </div>
  </div>
</div>