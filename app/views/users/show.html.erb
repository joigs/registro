<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 my-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-gray-900 p-6 rounded-lg shadow-md">

    <div>
      <h1 class="text-3xl font-bold text-white mb-2"><%= @user.username %></h1>

      <% if Current.user.id == @user.id %>

        <%= link_to "Modificar contraseña", edit_user_path(@user), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-gray-900 bg-blue-500 hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-150 ease-in-out" %>


      <% end %>



      </div>




  </div>





  <% if Current.user&.id == 1 %>
    <div class="mt-6 space-y-4">
      <%= form_with url: request.path, method: :get do %>
        <label for="mes" class="block text-sm font-medium text-white mb-2">Filtrar por mes</label>
        <%= select_tag :mes,
                       options_for_select(@opciones_meses, @mes_valor),
                       onchange: "this.form.submit()",
                       class: "block w-full rounded-md bg-gray-800 text-white border border-gray-700 p-2" %>

        <button type="submit" name="preview" value="1"
                class="mt-3 inline-flex items-center px-4 py-2 ml-6 rounded-md text-sm font-medium text-white bg-blue-600 hover:bg-blue-700">
          Previsualizar cambio de fecha
        </button>



      <% end %>

      <% if @aviso_cantidad %>
        <div class="rounded-md bg-yellow-100 text-yellow-900 p-3 text-sm space-y-2">
          <p>
            Se modificarían <strong><%= @aviso_cantidad %></strong> registros de CertChkLst.
            Su <code>CertChkLstFchFac</code> cambiaría a <strong><%= @aviso_fecha %></strong>.
          </p>

          <% if @aviso_cantidad > 0 %>
            <%= form_with url: actualizar_fac_perfil_path(username: @user.username), method: :post do %>
              <%= hidden_field_tag :mes, @mes_valor %>
              <button type="submit"
                      data-turbo-confirm="Se modificarán <%= @aviso_cantidad %> registros. ¿Confirmas?"
                      class="inline-flex items-center px-4 py-2 ml-6 rounded-md text-sm font-medium text-white bg-red-600 hover:bg-red-700">
                Confirmar y ejecutar
              </button>
            <% end %>
          <% end %>
        </div>
      <% end %>


      <table class="w-full text-sm text-white">
        <thead>
        <tr class="text-left border-b border-gray-700">
          <th class="py-2 pr-4 text-black">CertChkLstId</th>
          <th class="py-2 pr-4 text-black">CertActivoId</th>
          <th class="py-2 pr-4 text-black">CerManRut</th>
          <th class="py-2 pr-4 text-black">CertChkLstFch</th>
          <th class="py-2 pr-4 text-black">CertChkLstFchFac</th>
        </tr>
        </thead>
        <tbody>
        <% @cert_chk_lsts.each do |row| %>
          <tr class="border-b border-gray-800">
            <td class="py-2 pr-4 text-black"><%= row["CertChkLstId"] %></td>
            <td class="py-2 pr-4 text-black"><%= row["CertActivoId"] %></td>
            <td class="py-2 pr-4 text-black"><%= row["CerManRut"] %></td>
            <td class="py-2 pr-4 text-black"><%= row["CertChkLstFch"] %></td>
            <td class="py-2 pr-4 text-black"><%= row["CertChkLstFchFac"] %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% end %>




</div>