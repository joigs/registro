<div class="w-full max-w-md">
  <div class="flex flex-col items-center gap-3 mb-8">
    <div class="w-20 h-20 rounded-full bg-fm-accent-soft border-2 border-fm-accent flex items-center justify-center">
      <svg viewBox="0 0 24 24" class="w-9 h-9 text-fm-accent" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="9" cy="9" r="2" />
        <path d="M21 15l-5-5L5 21" />
      </svg>
    </div>
    <h1 class="text-3xl font-bold tracking-tight">Fotos Melón</h1>
    <p class="text-fm-text-muted">Panel de administradores</p>
  </div>

  <%= form_with model: @form,
                url: fotos_melon_admin_login_path,
                scope: :login_form,
                local: true,
                html: { class: "bg-white rounded-2xl border border-fm-border p-6 shadow-sm space-y-4",
                        "data-controller": "fotos-melon--admin--password-toggle" } do |f| %>

    <h2 class="text-xl font-semibold">Iniciar sesión</h2>
    <p class="text-sm text-fm-text-muted -mt-2">Usa tu correo electrónico de Midatech.</p>

    <div>
      <%= f.label :mail, "Correo electrónico", class: "block text-xs uppercase text-fm-text-muted tracking-wide font-medium mb-1" %>
      <%= f.email_field :mail,
                        autocomplete: "email",
                        autofocus: true,
                        required: true,
                        class: "w-full px-4 py-3 rounded-lg border border-fm-border bg-white focus:outline-none focus:ring-2 focus:ring-fm-accent-ring focus:border-fm-accent" %>
    </div>

    <div>
      <%= f.label :password, "Contraseña", class: "block text-xs uppercase text-fm-text-muted tracking-wide font-medium mb-1" %>
      <div class="relative">
        <%= f.password_field :password,
                             autocomplete: "current-password",
                             required: true,
                             data: { "fotos-melon--admin--password-toggle-target": "input" },
                             class: "w-full px-4 py-3 pr-12 rounded-lg border border-fm-border bg-white focus:outline-none focus:ring-2 focus:ring-fm-accent-ring focus:border-fm-accent" %>
        <button type="button"
                data-action="click->fotos-melon--admin--password-toggle#toggle"
                class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-fm-text-muted hover:text-fm-text"
                aria-label="Mostrar u ocultar contraseña">
          <svg data-fotos-melon--admin--password-toggle-target="iconShow" viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
          <svg data-fotos-melon--admin--password-toggle-target="iconHide" viewBox="0 0 24 24" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17.94 17.94A10.94 10.94 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A10.94 10.94 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" />
            <line x1="1" y1="1" x2="23" y2="23" />
          </svg>
        </button>
      </div>
    </div>

    <%= f.submit "Ingresar",
                 class: "w-full bg-fm-accent hover:bg-fm-accent-deep text-white font-semibold py-3 rounded-full transition" %>
  <% end %>


</div>