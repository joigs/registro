<% content_for :title, "Patentes · Fotos Melón Admin" %>

<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold tracking-tight">Patentes</h1>
  </div>

  <% if @patentes.empty? %>
    <div class="bg-white border border-fm-border rounded-2xl p-12 text-center">
      <p class="text-fm-text-muted">Aún no hay patentes registradas.</p>
    </div>
  <% else %>
    <ul class="space-y-2">
      <% @patentes.each do |p| %>
        <li class="bg-white border border-fm-border rounded-xl px-4 py-3">
          <span class="font-semibold"><%= p.nombre %></span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <p class="text-fm-text-muted text-sm pt-4">El detalle, crear, mover, descargar y galería llegan en la siguiente entrega.</p>
</div>