// Service worker de Fotos Melón Admin.
// Estrategia: cache-first para assets estáticos, network-first para HTML y datos.
// No cachea respuestas autenticadas porque rotan por usuario.

const CACHE_VERSION = "fm-admin-v1";
const SCOPE = "/ventas/fotos_melon/admin/";

// URLs a precachear (solo iconos y manifest, lo demás es dinámico).
const PRECACHE_URLS = [
    SCOPE + "manifest.json"
];

self.addEventListener("install", (event) => {
    event.waitUntil(
        caches.open(CACHE_VERSION).then((cache) => cache.addAll(PRECACHE_URLS).catch(() => {}))
    );
    self.skipWaiting();
});

self.addEventListener("activate", (event) => {
    event.waitUntil(
        caches.keys().then((keys) => {
            return Promise.all(
                keys.filter((k) => k !== CACHE_VERSION && k.startsWith("fm-admin-")).map((k) => caches.delete(k))
            );
        }).then(() => self.clients.claim())
    );
});

self.addEventListener("fetch", (event) => {
    const url = new URL(event.request.url);

    if (!url.pathname.startsWith(SCOPE)) return;

    if (event.request.method !== "GET") return;

    const esAssetEstatico = /\.(?:png|jpg|jpeg|svg|webp|ico|woff2?)$/i.test(url.pathname);

    if (esAssetEstatico) {
        event.respondWith(
            caches.match(event.request).then((cached) => {
                if (cached) return cached;
                return fetch(event.request).then((res) => {
                    if (res.ok) {
                        const copia = res.clone();
                        caches.open(CACHE_VERSION).then((c) => c.put(event.request, copia));
                    }
                    return res;
                }).catch(() => cached);
            })
        );
    }
});