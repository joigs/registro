<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0A84FF" />
  <title>Iniciar sesión · Fotos Melón Admin</title>

  <link rel="manifest" href="/ventas/fotos_melon/admin/manifest.json" />

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-fm-bg text-fm-text min-h-screen antialiased flex items-center justify-center px-4"
      data-controller="fotos-melon--admin--sw">

<% if flash.any? %>
  <div class="fixed top-4 left-4 right-4 max-w-md mx-auto space-y-2 z-50">
    <% flash.each do |tipo, msg| %>
      <% color = tipo.to_s == "alert" ? "danger" : "success" %>
      <div class="px-4 py-3 rounded-xl border <%= color == 'danger' ? 'bg-red-50 text-red-800 border-red-200' : 'bg-green-50 text-green-800 border-green-200' %>">
        <%= msg %>
      </div>
    <% end %>
  </div>
<% end %>

<%= yield %>

</body>
</html>